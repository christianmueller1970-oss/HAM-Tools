# SPM
.build

# Build-Artefakte (App-Bundle, DMGs)
HAMRechner.app/
*.dmg

# Lizenz-Generator: Release-App-Bundle aus tools/HAMToolsLicenseGen/build.sh.
# Wird reproduzierbar gebaut, gehört nicht ins Repo.
tools/HAMToolsLicenseGen/dist/

# Icon-Build (aus icon-source.svg generierbar)
AppIcon.icns
AppIcon.iconset/

# Web (Vue 3) Build-Output und Dependencies
web-vue/dist/
web-vue/node_modules/
web-vue/.vite/

# Claude Code: Memory-Backup wird via Google Drive synct, nicht via Git
claude-memory-backup/
.claude/settings.local.json

# CAT-Anbindung: rigctld-Binary wird reproduzierbar via scripts/build-hamlib.sh
# erzeugt (Universal2, Hamlib-Source-Build). Nicht ins Git, da 22 MB + Drive-
# Mode-Bit-Problem. Build automatisch im build-dmg.sh falls fehlend.
vendor/hamlib/rigctld

# Lizenz-Generator: Ed25519-Private-Key liegt im UserAppSupport-Ordner und
# darf NIE ins Repo. Belt-and-Suspenders falls mal ein Test-Keypair im
# Projektverzeichnis landet.
keypair.json
*.keypair.json

# Update-Manifest: generiertes Artefakt aus tools/sign-updates.swift, wird
# nach jedem Release neu signiert (Signatur ist probabilistisch).
# Live-Version liegt auf toolbox.funkwelt.net/app/updates.json.
updates.json
